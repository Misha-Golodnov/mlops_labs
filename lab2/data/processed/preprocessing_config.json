{
  "preprocessing_metadata": {
    "version": "1.0",
    "dataset": "Wine Quality Red",
    "source_url": "https://archive.ics.uci.edu/ml/machine-learning-databases/wine-quality/winequality-red.csv",
    "processing_date": "2026-03-29"
  },
  "data_statistics": {
    "original_rows": 1599,
    "original_features": 11,
    "original_target_column": "quality",
    "rows_after_preprocessing": 1589,
    "features_removed": 0,
    "outliers_removed": 10,
    "missing_values": 0
  },
  "train_test_split": {
    "method": "stratified_train_test_split",
    "test_size": 0.2,
    "random_state": 42,
    "stratify_column": "quality",
    "train_samples": 1271,
    "test_samples": 318
  },
  "preprocessing_steps": [
    {
      "step": 1,
      "name": "Handle Missing Values",
      "method": "fill_with_median",
      "parameters": {},
      "missing_values_found": 0
    },
    {
      "step": 2,
      "name": "Remove Outliers",
      "method": "z_score",
      "parameters": {
        "z_threshold": 3.0,
        "column": "quality"
      },
      "outliers_removed": 10
    },
    {
      "step": 3,
      "name": "Feature Importance Analysis",
      "method": "random_forest",
      "parameters": {
        "n_estimators": 100,
        "random_state": 42,
        "importance_threshold": 0.01
      },
      "features_selected": 11
    },
    {
      "step": 4,
      "name": "Feature Scaling",
      "method": "StandardScaler",
      "parameters": {
        "with_mean": true,
        "with_std": true
      },
      "description": "Z-score normalization: (x - mean) / std"
    }
  ],
  "feature_importance": {
    "scoring_method": "Random Forest Mean Decrease in Impurity",
    "top_features": [
      {
        "rank": 1,
        "name": "alcohol",
        "importance": 0.27823,
        "percentage": 27.82
      },
      {
        "rank": 2,
        "name": "sulphates",
        "importance": 0.13957,
        "percentage": 13.96
      },
      {
        "rank": 3,
        "name": "volatile acidity",
        "importance": 0.11125,
        "percentage": 11.13
      },
      {
        "rank": 4,
        "name": "total sulfur dioxide",
        "importance": 0.08254,
        "percentage": 8.25
      },
      {
        "rank": 5,
        "name": "chlorides",
        "importance": 0.06496,
        "percentage": 6.50
      }
    ]
  },
  "selected_features": [
    "alcohol",
    "sulphates",
    "volatile acidity",
    "total sulfur dioxide",
    "chlorides",
    "pH",
    "residual sugar",
    "density",
    "citric acid",
    "fixed acidity",
    "free sulfur dioxide"
  ],
  "output_files": {
    "X_train": {
      "path": "data/processed/X_train.csv",
      "rows": 1271,
      "columns": 11,
      "format": "CSV",
      "delimiter": ","
    },
    "X_test": {
      "path": "data/processed/X_test.csv",
      "rows": 318,
      "columns": 11,
      "format": "CSV",
      "delimiter": ","
    },
    "y_train": {
