      "format": "pickle",
      "description": "Use this scaler to transform new data before making predictions"
    },
    "feature_importance": {
      "path": "data/processed/feature_importance.csv",
      "rows": 11,
      "columns": 2,
      "format": "CSV",
      "delimiter": ",",
      "column_names": ["feature", "importance"]
    },
    "important_features": {
      "path": "data/processed/important_features.txt",
      "rows": 11,
      "format": "text",
