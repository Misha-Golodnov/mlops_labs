pipeline {
    agent any

    options {
        timestamps()
    }

    stages {
        stage('Install dependencies') {
            steps {
                dir('lab2') {
                    bat 'python -m pip install -r requirements.txt'
                }
            }
        }

        stage('Load Wine Quality and split features') {
            steps {
                dir('lab2') {
                    bat 'python scripts/load_and_split_wine_quality.py'
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline finished: raw and processed data are under lab2/data/'
        }
        failure {
            echo 'Pipeline failed: check agent has python3, pip, and network to UCI'
        }
    }
}
